# Copy to `.env` and fill in. The lesson scripts read this file and write
# YAKYAK_TOKEN / YAKYAK_USER_ID back into it after you sign in.

# Build the tutorial against beta.
YAKYAK_API_BASE=https://api.beta.yakyak.ai

# Your student email (any address you can receive mail at).
YAKYAK_EMAIL=student@example.com
# Leave blank to have 01-signup generate a strong password and save it here.
# (That password also works for signing into the YakYak web app.)
YAKYAK_PASSWORD=

# Filled in automatically by 01-signup.
YAKYAK_TOKEN=
YAKYAK_USER_ID=

# Lesson 2 forks this source episode (the "Fruit Island Tutorial" template on beta).
YAKYAK_TUTORIAL_CAMPAIGN_ID=d0bb3577-af7a-411d-a8bc-42cbee4b165d
YAKYAK_TUTORIAL_MOVIE_ID=309399f6-e23f-4020-afd3-35d5ae57b74c
