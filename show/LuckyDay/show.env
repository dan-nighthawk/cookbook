# "Lucky Day" — daily Chinese feng-shui almanac. A COMPUTED example show: the
# story is generated deterministically from the date by compute.py (no model /
# API key needed). The SECOND computed show after Horoscopes, and the first in
# Chinese — spoken in Mandarin (voice Mr. Chen) with brush-calligraphy subtitles.
# Run:
#   showrunner/prepare.sh            marketing/LuckyDay
#   showrunner/upload_to_yakyak.py --show marketing/LuckyDay
# See marketing/showrunner/README.md and docs/alternative_setups.md (#2).

# ---- engine / render ------------------------------------------------------
# Leave CAMPAIGN_ID empty and run the one-time setup, which imports
# campaign.import.json, generates the 13 cast portraits, and fills this in:
#   YAKYAK_PAT=yy_live_... ./marketing/showrunner/setup_show.sh marketing/LuckyDay
# (campaign.import.json carries the 12-animal + Feng Shui Master roster, one gold
# Ma Shan Zheng subtitle style, one shared native-Mandarin voice (Mr. Chen,
# cwzmKSYMCC9Aym1ymCnt), and 9:16/kenburns/ink-wash config; no rendered assets.)
CAMPAIGN_ID="babe443e-f80a-481c-9dde-6ba3bfa98b60"
# Soundtrack: leave empty and setup_show.sh composes one AI track (from
# MUSIC_PROMPT below) once on the template, then writes the resulting audioPath
# here — reused by every episode. Set a path manually to skip composition.
SOUNDTRACK_AUDIO_PATH="prd/ugc/f7d7cf1c-215c-42b2-92ee-1bb06bb46fd1/babe443e-f80a-481c-9dde-6ba3bfa98b60/39adc355-80a4-4a1d-b296-7f07953a0e00/audio/f47a008e-fa9f-4800-90a6-def89d5382b7.mp3"
# Mood for the one-time AI soundtrack compose (falls back to the API's suggestion).
MUSIC_PROMPT="Traditional Chinese instrumental: guzheng and erhu over soft lo-fi pads, calm, auspicious and contemplative, gentle wood-block pulse"
VOLUME="30"
MIN_TOKEN_BALANCE="2000"
STORY_GLOB="*_lucky_day.md"

# Cast: the 12 Chinese zodiac animals + The Feng Shui Master (opens scene 1,
# closes scene 14). Leading-character names are the bare English names ("Rat",
# "Ox", ... "The Feng Shui Master") emitted by compute.py. The Master is listed
# first so it wins the substring match unambiguously.
CAST_ALIASES="The Feng Shui Master=The Feng Shui Master,Rat=Rat,Ox=Ox,Tiger=Tiger,Rabbit=Rabbit,Dragon=Dragon,Snake=Snake,Horse=Horse,Goat=Goat,Monkey=Monkey,Rooster=Rooster,Dog=Dog,Pig=Pig"

# Single shared PAT (default key YAKYAK_PAT; legacy YAKYAK_BB_PAT also honored).
# PAT_ENV_KEY="YAKYAK_PAT"

# ---- prepare (story sourcing) ---------------------------------------------
# Deterministic generator: compute.py. No claude / ANTHROPIC_API_KEY needed.
PREPARE_KIND="compute"
STORY_SUFFIX="_lucky_day.md"
REQUIRES_MODEL="false"

# ---- CI / scheduling ------------------------------------------------------
# Daily (the catalog frames Lucky Day as a daily almanac). Disabled until you
# flip ENABLED=true after a local setup + first render. NOTE: a full episode is
# 14 scenes (Master + 12 animals); if daily token cost is too high, trim the
# animal loop in compute.py or switch CADENCE to "weekly".
CADENCE="daily"
ENGINE="py"
ENABLED="false"
# Set true to PUBLISH to social on scheduled runs (irreversible). Default render-only.
POST="false"
