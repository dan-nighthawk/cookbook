# Breaking Bricks News — show config (consumed by show/showrunner/upload_to_yakyak.*)
# KEY=VALUE, shell-style. Comments MUST be on their own line (the loaders do not
# strip trailing inline comments). Run with:
#   showrunner/upload_to_yakyak.py --show show/BreakingBricksNews
# See show/showrunner/README.md for the full key reference.

# ---- engine / render ------------------------------------------------------
# BBN production campaign.
CAMPAIGN_ID="a7e7b9c5-0959-41a0-9176-509a3b197775"

# audioPath of the BBN intro track (lives on the "Power Struggle" sibling
# episode). Set directly on the new episode; the render reuses it from the CDN.
SOUNDTRACK_AUDIO_PATH="beta/ugc/5c07cc65-fa83-48ef-9050-cf7f4e5fcd47/62c9e486-2a80-49dd-afeb-5c5dba416cb9/a4bd102c-3a8f-44c4-b042-f675e79264e6/audio/2c53f283-6b9f-482a-a8f0-a37ba7b5a194.mp3"

VOLUME="45"
MIN_TOKEN_BALANCE="2000"
STORY_GLOB="*_latest_update.md"

# Cast map: leading-character full name (substring) -> screenplay alias, in
# priority order. Both Mojtaba and Khamenei collapse to "Mojtaba".
CAST_ALIASES="Bob=Bob,Trump=Trump,Netanyahu=Netanyahu,Mojtaba=Mojtaba,Khamenei=Mojtaba,Pilot=Pilot"

# PAT: single shared token. Default key is YAKYAK_PAT; the engine also falls back
# to the legacy YAKYAK_BB_PAT, so an existing e2e/.env.bb keeps working locally.
# Uncomment to pin a different env var name for this show's token:
# PAT_ENV_KEY="YAKYAK_PAT"

# ---- prepare (story sourcing) ---------------------------------------------
# prompt.md driven by `claude -p` (WebFetch + Write).
PREPARE_KIND="prompt"
STORY_SUFFIX="_latest_update.md"
# CI: needs ANTHROPIC_API_KEY + the -claude image.
REQUIRES_MODEL="true"

# ---- CI / scheduling ------------------------------------------------------
# plan_due_shows.sh uses CADENCE to pick the day's runs.
CADENCE="daily"
# Which port CI runs for this show (py|js|sh).
ENGINE="py"
# Set false to skip in scheduled runs.
ENABLED="true"
# Set true to PUBLISH to social on scheduled runs (irreversible). Default render-only.
POST="true"
