# "Cosmic Brief" — weekly horoscopes. A COMPUTED example show: the story is
# generated deterministically from the ISO week by compute.py (no model / API
# key needed), proving the showrunner engine is fully show-agnostic.
# Run:
#   showrunner/prepare.sh            marketing/Horoscopes
#   showrunner/upload_to_yakyak.py --show marketing/Horoscopes
# See marketing/showrunner/README.md and docs/alternative_setups.md (#1).

# ---- engine / render ------------------------------------------------------
# Leave CAMPAIGN_ID empty and run the one-time setup, which imports
# campaign.import.json, generates the 13 cast portraits, and fills this in:
#   YAKYAK_PAT=yy_live_... ./marketing/showrunner/setup_show.sh marketing/Horoscopes
# (campaign.import.json carries the 12-sign + Cosmic Guru cast roster, per-sign
# subtitle colors, one shared Brian voice, and 9:16/kenburns/style config; no
# rendered assets. Ken Burns is the interim animation while Kling AI is in progress.)
CAMPAIGN_ID="956e3d49-bf6c-4fd4-ab92-67ef3329b299"
# Soundtrack: leave empty and setup_show.sh composes one AI track (from
# MUSIC_PROMPT below) once on the template, then writes the resulting audioPath
# here — reused by every episode. Set a path manually to skip composition.
SOUNDTRACK_AUDIO_PATH="prd/ugc/f7d7cf1c-215c-42b2-92ee-1bb06bb46fd1/956e3d49-bf6c-4fd4-ab92-67ef3329b299/d14535e8-830b-4d04-9285-9ef00d7e9d73/audio/ac17c6fe-419e-467c-9f56-9b8839595eee.mp3"
# Mood for the one-time AI soundtrack compose (falls back to the API's suggestion).
MUSIC_PROMPT="Ambient celestial instrumental: warm analog pads, soft chimes and distant choir, slow, mystical and contemplative"
VOLUME="30"
MIN_TOKEN_BALANCE="2000"
STORY_GLOB="*_cosmic_brief.md"

# Cast: the 12 zodiac avatars + The Cosmic Guru (opens scene 1, closes scene 14).
# Leading-character names like "Aries the Ram" match the "Aries" substring ->
# alias "Aries". "The Cosmic Guru" maps to itself; it's listed first so it wins
# the substring match unambiguously.
CAST_ALIASES="The Cosmic Guru=The Cosmic Guru,Aries=Aries,Taurus=Taurus,Gemini=Gemini,Cancer=Cancer,Leo=Leo,Virgo=Virgo,Libra=Libra,Scorpio=Scorpio,Sagittarius=Sagittarius,Capricorn=Capricorn,Aquarius=Aquarius,Pisces=Pisces"

# Single shared PAT (default key YAKYAK_PAT; legacy YAKYAK_BB_PAT also honored).
# PAT_ENV_KEY="YAKYAK_PAT"

# ---- prepare (story sourcing) ---------------------------------------------
# Deterministic generator: compute.py. No claude / ANTHROPIC_API_KEY needed.
PREPARE_KIND="compute"
STORY_SUFFIX="_cosmic_brief.md"
REQUIRES_MODEL="false"

# ---- CI / scheduling ------------------------------------------------------
# Weekly (the plan script runs CADENCE=weekly shows on Sundays).
CADENCE="weekly"
ENGINE="py"
ENABLED="false"
