# "Market Mayhem" — daily crypto & markets show (#6 in docs/alternative_setups.md).
# A WEBFETCH show: prompt.md (driven by `claude -p`) fetches the day's real prices
# (Binance 24h ticker) + the Fear & Greed index, computes the movers, and dramatizes
# them with a recurring cast of personified assets. Run:
#   showrunner/prepare.sh            marketing/MarketMayhem
#   showrunner/upload_to_yakyak.py --show marketing/MarketMayhem
# See marketing/showrunner/README.md and docs/alternative_setups.md (#6).

# ---- engine / render ------------------------------------------------------
# Leave CAMPAIGN_ID empty and run the one-time setup, which imports
# campaign.import.json, generates the 6 cast portraits, composes the soundtrack,
# renders a trailer, bootstraps season 1, and fills these in:
#   YAKYAK_PAT=yy_live_... ./marketing/showrunner/setup_show.sh marketing/MarketMayhem
# (campaign.import.json carries the Max Mayhem anchor + 5 personified-asset roster,
# per-asset Orbitron subtitle colors, distinct voices per character, and
# 9:16/kenburns/Anime-Manga config; no rendered assets. Ken Burns is the reliable
# interim animation while Kling AI is in progress — the doc's #6 target is Kling.)
CAMPAIGN_ID="734c5d0a-ed65-4b4e-8abe-6925a69ff35b"
# Soundtrack: leave empty and setup_show.sh composes one AI track (from
# MUSIC_PROMPT below) once on the template, then writes the resulting audioPath
# here — reused by every episode. Set a path manually to skip composition.
SOUNDTRACK_AUDIO_PATH="prd/ugc/f7d7cf1c-215c-42b2-92ee-1bb06bb46fd1/734c5d0a-ed65-4b4e-8abe-6925a69ff35b/b00ce378-238e-4c92-8262-f41c79eec793/audio/1386f826-10e0-4cd7-9323-e6261b129c02.mp3"
# Mood for the one-time AI soundtrack compose (falls back to the API's suggestion).
MUSIC_PROMPT="Tense electronic instrumental: pulsing synth arpeggios, driving bassline, ticking-clock percussion, anxious and propulsive, financial-thriller energy"
VOLUME="45"
MIN_TOKEN_BALANCE="2000"
STORY_GLOB="*_market_mayhem.md"

# Cast: Max Mayhem (anchor; opens scene 1, closes scene 8) + the 5 personified
# assets. Leading-character names emitted by prompt.md are the bare cast names.
# Max Mayhem and The Fed are listed first so their multi-word names win the
# substring match unambiguously.
CAST_ALIASES="Max Mayhem=Max Mayhem,The Fed=The Fed,Bitcoin=Bitcoin,Ethereum=Ethereum,Doge=Doge,Gold=Gold"

# Single shared PAT (default key YAKYAK_PAT; legacy YAKYAK_BB_PAT also honored).
# PAT_ENV_KEY="YAKYAK_PAT"

# ---- prepare (story sourcing) ---------------------------------------------
# prompt.md driven by `claude -p` (WebFetch + Write).
PREPARE_KIND="prompt"
STORY_SUFFIX="_market_mayhem.md"
# CI: needs ANTHROPIC_API_KEY + the -claude image.
REQUIRES_MODEL="true"

# ---- CI / scheduling ------------------------------------------------------
# Daily at market close (the flagship daily-cron case). Disabled until you flip
# ENABLED=true after a local setup + first verified render.
CADENCE="daily"
ENGINE="py"
ENABLED="false"
