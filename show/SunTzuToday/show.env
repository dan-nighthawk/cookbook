# "Sun Tzu, Today" — ancient strategy for modern life (#3 in docs/alternative_setups.md).
# The FIRST "Extracted" show: each episode dramatizes ONE verbatim maxim from a
# public-domain corpus (corpus/art_of_war.md — Lionel Giles 1910, Project Gutenberg
# #132), walked one maxim per episode by compute.js (cursor = number of files in
# stories/). compute.js calls `claude -p` to stage the maxim as a modern micro-drama,
# so this is a compute show that still needs a model (REQUIRES_MODEL="true"). Run:
#   showrunner/prepare.sh            show/SunTzuToday
#   node showrunner/upload_to_yakyak.js --show show/SunTzuToday
# See show/showrunner/README.md and docs/alternative_setups.md (#3).

# ---- engine / render ------------------------------------------------------
# Leave CAMPAIGN_ID empty and run the one-time setup, which imports
# campaign.import.json, generates the 3 cast portraits, composes the soundtrack,
# renders a trailer, bootstraps season 1, and fills these in:
#   YAKYAK_PAT=yy_live_... ./show/showrunner/setup_show.sh show/SunTzuToday
# (campaign.import.json carries The Strategist + The Student + The Rival roster,
# per-character Cinzel subtitle colors, distinct voices, and 9:16/kenburns/Oil-Painting
# config; no rendered assets. Ken Burns is the reliable interim animation while Kling AI
# — the doc's #3 target for duel motion — is in progress.)
CAMPAIGN_ID="4ce7705d-a183-4e7d-b325-d686b65e1baa"
# Soundtrack: leave empty and setup_show.sh composes one AI track (from MUSIC_PROMPT
# below) once on the template, then writes the resulting audioPath here.
SOUNDTRACK_AUDIO_PATH="prd/ugc/f7d7cf1c-215c-42b2-92ee-1bb06bb46fd1/17875332-6967-4111-bd22-2b8e344ddcd8/da15b8b9-f309-4ffa-8b32-dd80f8aff78b/audio/7a1f7eef-83d6-44d6-91cf-fe85f7b84884.mp3"
# Mood for the one-time AI soundtrack compose (falls back to the API's suggestion).
MUSIC_PROMPT="Sparse cinematic taiko: deep tribal war-drums and a single struck temple bell, long silences between hits, tense and meditative, ink-and-steel atmosphere"
VOLUME="35"
MIN_TOKEN_BALANCE="2000"
STORY_GLOB="*_sun_tzu.md"

# Cast: The Strategist (Guru; opens scene 1 stating the maxim, closes scene 7),
# The Student (Protagonist), The Rival (Antagonist). Names emitted by compute.js
# are the bare cast names. "The Strategist" listed first so it wins the substring match.
CAST_ALIASES="The Strategist=The Strategist,The Student=The Student,The Rival=The Rival"

# Single shared PAT (default key YAKYAK_PAT; legacy YAKYAK_BB_PAT also honored).
# PAT_ENV_KEY="YAKYAK_PAT"

# ---- prepare (story sourcing) ---------------------------------------------
# Deterministic verse selection in compute.js, dramatized via `claude -p`.
PREPARE_KIND="compute"
STORY_SUFFIX="_sun_tzu.md"
# compute.js shells out to `claude`, so CI must run it in the claude-enabled
# -prepare image (which has node) — gated by REQUIRES_MODEL.
REQUIRES_MODEL="true"

# ---- CI / scheduling ------------------------------------------------------
# 3x/week — Mon/Wed/Fri (the 'mwf' cadence in plan_due_shows.sh). Disabled until a
# local setup + first verified render; flip ENABLED=true when ready.
CADENCE="mwf"
# JS engine port: CI runs the showrunner-js image and `node upload_to_yakyak.js`.
ENGINE="js"
ENABLED="false"
# Set true to PUBLISH to social on scheduled runs (irreversible). Default render-only.
POST="false"
