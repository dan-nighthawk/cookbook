# "Daily Pull" — daily tarot (#8 in docs/alternative_setups.md). The FIRST
# "Randomized (seeded)" show: each episode draws a 3-card Past/Present/Future
# spread from the 22 Major Arcana with a DATE-SEEDED RNG in compute.js (same day
# in → same draw out; the seed + draw are logged into each story as an audit
# marker, and the last 7 draws are excluded so cards don't repeat within a week).
# compute.js then calls `claude -p` to stage the reading as a 5-scene episode —
# The Reader (mystic host) opens & closes; the three drawn cards are personified
# and lead the middle scenes. A compute show that still needs a model
# (REQUIRES_MODEL="true"). Run:
#   showrunner/prepare.sh            marketing/DailyPull
#   node showrunner/upload_to_yakyak.js --show marketing/DailyPull
# See marketing/showrunner/README.md and docs/alternative_setups.md (#8).

# ---- engine / render ------------------------------------------------------
# Leave CAMPAIGN_ID empty and run the one-time setup, which imports
# campaign.import.json, generates the 23 cast portraits (The Reader + 22 Major
# Arcana), composes the soundtrack, renders a trailer, and fills these in:
#   YAKYAK_PAT=yy_live_... ./marketing/showrunner/setup_show.sh marketing/DailyPull
# (campaign.import.json carries the 23-member recurring roster with per-card
# Cinzel subtitle accent colours and distinct voices, plus 9:16/kenburns/
# Digital-Painting config; no rendered assets. allowNewCharacters=false because
# the entire draw pool pre-exists, so every drawn card has a stable portrait.
# Ken Burns is the candle-lit interim animation while Kling AI is in progress.)
CAMPAIGN_ID="de4faab5-c447-4357-afe9-fce57a5795e7"
# Soundtrack: leave empty and setup_show.sh composes one AI track (from
# MUSIC_PROMPT below) once on the template, then writes the resulting audioPath
# here — reused by every episode. Set a path manually to skip composition.
SOUNDTRACK_AUDIO_PATH="prd/ugc/f7d7cf1c-215c-42b2-92ee-1bb06bb46fd1/628da8c6-7157-4bdf-b66b-f388484aca36/b1b0749d-9682-4e03-b875-e1738ac2a0c1/audio/bc493932-b6bc-4161-97c1-c897ecb1bcb6.mp3"
# Mood for the one-time AI soundtrack compose (falls back to the API's suggestion).
MUSIC_PROMPT="Mystical ASMR-leaning ambient: soft warm pad, distant chimes and singing bowls, a slow heartbeat of low drum, candle-lit, hushed and hypnotic"
VOLUME="30"
MIN_TOKEN_BALANCE="2000"
STORY_GLOB="*_daily_pull.md"

# Cast: The Reader (mystic host; opens scene 1, closes scene 5) + the 22 Major
# Arcana, each mapped to its exact card name. compute.js emits the bare card name
# (e.g. "Death", "The Tower") as the leading character, so every alias maps a full
# name to itself. No card name is a substring of another, so order is unambiguous.
CAST_ALIASES="The Reader=The Reader,The High Priestess=The High Priestess,The Hierophant=The Hierophant,The Hanged Man=The Hanged Man,The Hermit=The Hermit,The Magician=The Magician,The Emperor=The Emperor,The Empress=The Empress,The Lovers=The Lovers,The Chariot=The Chariot,The Fool=The Fool,The Devil=The Devil,The Tower=The Tower,The Star=The Star,The Moon=The Moon,The Sun=The Sun,The World=The World,Wheel of Fortune=Wheel of Fortune,Strength=Strength,Justice=Justice,Death=Death,Temperance=Temperance,Judgement=Judgement"

# Single shared PAT (default key YAKYAK_PAT; legacy YAKYAK_BB_PAT also honored).
# PAT_ENV_KEY="YAKYAK_PAT"

# ---- prepare (story sourcing) ---------------------------------------------
# Date-seeded draw in compute.js, dramatized via `claude -p`.
PREPARE_KIND="compute"
STORY_SUFFIX="_daily_pull.md"
# compute.js shells out to `claude`, so CI must run it in the claude-enabled
# -prepare image (which has node) — gated by REQUIRES_MODEL.
REQUIRES_MODEL="true"

# ---- CI / scheduling ------------------------------------------------------
# Daily — the doc's flagship cadence for the scheduled container. Disabled until a
# local setup + first verified render; flip ENABLED=true when ready.
CADENCE="daily"
# JS engine port: CI runs the showrunner-js image and `node upload_to_yakyak.js`.
ENGINE="js"
ENABLED="false"
# Set true to PUBLISH to social on scheduled runs (irreversible). Default render-only.
POST="false"
