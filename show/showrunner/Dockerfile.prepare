# Showrunner PREPARE image — for prompt-based (WebFetch/LLM) shows like BBN whose
# story is generated by `claude -p`. Build from the REPO ROOT:
#   docker build -f marketing/showrunner/Dockerfile.prepare -t yakyak/showrunner-prepare .
#
# COMPUTE shows (e.g. Horoscopes) do NOT need this image — their compute.py runs
# in the plain engine images. Use this only when PREPARE_KIND=prompt.
#
# Needs ANTHROPIC_API_KEY at run time for the headless `claude` CLI:
#   docker run --rm -e ANTHROPIC_API_KEY \
#     -v "$PWD/marketing/BreakingBricksNews/stories:/app/marketing/BreakingBricksNews/stories" \
#     --entrypoint marketing/showrunner/prepare.sh \
#     yakyak/showrunner-prepare marketing/BreakingBricksNews
FROM python:3.12-slim

# Node is needed only to install the Claude Code CLI. Pin the CLI version in CI
# for reproducible prepares.
RUN apt-get update && apt-get install -y --no-install-recommends \
      nodejs npm bash ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @anthropic-ai/claude-code

WORKDIR /app
COPY marketing/showrunner/requirements.txt marketing/showrunner/requirements.txt
RUN pip install --no-cache-dir -r marketing/showrunner/requirements.txt
COPY marketing/ marketing/
RUN mkdir -p /app/e2e && touch /app/e2e/.env.bb \
    && chmod +x marketing/showrunner/prepare.sh

# Default to the prepare step; override --entrypoint to run an engine instead.
ENTRYPOINT ["marketing/showrunner/prepare.sh"]
