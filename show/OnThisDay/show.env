# "On This Day" — historical reenactment, one anniversary a day (#7 in docs/alternative_setups.md).
# The "Computed (date) + Extracted (public-domain history)" archetype: compute.js
# keys off today's calendar date, selects an anniversary from a baked public-domain
# corpus (corpus/on_this_day.md), and calls `claude -p` to stage it as a dramatized
# reenactment framed by the recurring host, The Chronicler. Computed + Extracted =
# reproducible, offline, zero licensing — but it still needs a model to dramatize,
# so REQUIRES_MODEL="true". Run:
#   showrunner/prepare.sh            show/OnThisDay
#   node showrunner/upload_to_yakyak.js --show show/OnThisDay
# See show/showrunner/README.md and docs/alternative_setups.md (#7).

# ---- engine / render ------------------------------------------------------
# Leave CAMPAIGN_ID empty and run the one-time setup, which imports
# campaign.import.json, generates The Chronicler's portrait, composes the
# soundtrack, renders a trailer, bootstraps the first episode, and fills these in:
#   YAKYAK_PAT=yy_live_... ./show/showrunner/setup_show.sh show/OnThisDay
# (campaign.import.json carries ONLY the recurring host, The Chronicler, with a
# Cinzel sepia-gold subtitle and a documentary-gravitas voice, plus 16:9 / kenburns /
# Photorealism config with allowNewCharacters=TRUE so the day's historical figures
# are introduced per episode. No rendered assets. Ken Burns is the reliable interim
# animation; Kling AI — the doc's #7 target for the dramatic centerpiece — is in progress.)
CAMPAIGN_ID="209b2a8e-0ddd-4658-aa5d-e8ff8b0f09a6"
# Soundtrack: leave empty and setup_show.sh composes one AI track (from MUSIC_PROMPT
# below) once on the template, then writes the resulting audioPath here.
SOUNDTRACK_AUDIO_PATH="prd/ugc/f7d7cf1c-215c-42b2-92ee-1bb06bb46fd1/b9575d7d-ea5c-4e48-875e-0619e7a0fb3f/cba4cab7-0c2a-4bdd-9f29-f818cee48787/audio/e3dea9a1-d647-432f-8b44-645439a13a8f.mp3"
# Mood for the one-time AI soundtrack compose (falls back to the API's suggestion).
MUSIC_PROMPT="Sweeping cinematic orchestral score for a history documentary: solemn strings, distant horns and a slow timpani pulse, dignified and stirring, the sound of great events remembered"
VOLUME="35"
MIN_TOKEN_BALANCE="2000"
STORY_GLOB="*_on_this_day.md"

# Cast: only the recurring host is aliased. The day's historical figures are
# episodic (allowNewCharacters) and keep the names compute.js / the screenplay emit.
CAST_ALIASES="The Chronicler=The Chronicler"

# Single shared PAT (default key YAKYAK_PAT; legacy YAKYAK_BB_PAT also honored).
# PAT_ENV_KEY="YAKYAK_PAT"

# ---- prepare (story sourcing) ---------------------------------------------
# Deterministic date->event selection in compute.js, dramatized via `claude -p`.
PREPARE_KIND="compute"
STORY_SUFFIX="_on_this_day.md"
# compute.js shells out to `claude`, so CI must run it in the claude-enabled
# -prepare image (which has node) — gated by REQUIRES_MODEL.
REQUIRES_MODEL="true"

# ---- CI / scheduling ------------------------------------------------------
# Daily — "today in history" is a daily format. Disabled until a local setup +
# first verified render; flip ENABLED=true when ready.
CADENCE="daily"
# JS engine port: CI runs the showrunner-js image and `node upload_to_yakyak.js`.
ENGINE="js"
ENABLED="false"
# Set true to PUBLISH to social on scheduled runs (irreversible). Default render-only.
POST="false"
