# "Petty Court" — daily Reddit/AITA drama reenactments (#9 in docs/alternative_setups.md).
# A WEBFETCH show: prompt.md (driven by `claude -p`) fetches the day's top posts from
# the drama subreddits via Reddit's public JSON, picks one high-upvote story, PARAPHRASES
# it (transformative + SFW — never reproduce text verbatim), and stages it as a small-
# claims sitcom presided over by a recurring Judge with a fixed roster of litigant
# archetypes. The upvote count is the built-in virality pre-screen. Run:
#   showrunner/prepare.sh            show/PettyCourt
#   showrunner/upload_to_yakyak.py --show show/PettyCourt
# See show/showrunner/README.md and docs/alternative_setups.md (#9).

# ---- engine / render ------------------------------------------------------
# Leave CAMPAIGN_ID empty and run the one-time setup, which imports
# campaign.import.json, generates the 6 cast portraits, composes the soundtrack,
# renders a trailer, bootstraps season 1, and fills these in:
#   YAKYAK_PAT=yy_live_... ./show/showrunner/setup_show.sh show/PettyCourt
# (campaign.import.json carries the Judge Justine Payne anchor + 5 recurring litigant
# archetypes — Marlene the Monster-in-Law, Trevor the Freeloader, Bridezilla Bree,
# Dex the Petty Ex, Reasonable Ray — per-character Bangers subtitle colors, distinct
# voices per character, and 9:16/kenburns/Cartoon-3D config; no rendered assets. Ken
# Burns is the reliable interim animation while Kling AI is in progress — the doc's
# #9 target is Ken Burns reaction shots + comedic zoom punches.)
CAMPAIGN_ID="e98010e1-6fc0-4c1c-b0a0-770fc60e3339"
# Soundtrack: leave empty and setup_show.sh composes one AI track (from
# MUSIC_PROMPT below) once on the template, then writes the resulting audioPath
# here — reused by every episode. Set a path manually to skip composition.
SOUNDTRACK_AUDIO_PATH="prd/ugc/f7d7cf1c-215c-42b2-92ee-1bb06bb46fd1/4952f10c-16f8-4bb6-a5a1-d636047a7ec4/ef1985eb-6816-4dc0-a757-0ed48674706b/audio/9453171e-0962-4588-8a08-8c2415d32188.mp3"
# Mood for the one-time AI soundtrack compose (falls back to the API's suggestion).
MUSIC_PROMPT="Upbeat daytime-TV courtroom sitcom theme: bouncy walking bassline, jazzy muted-brass stabs, comedic woodblock and gavel hits, retro game-show energy, cheeky and light"
VOLUME="45"
MIN_TOKEN_BALANCE="2000"
STORY_GLOB="*_petty_court.md"

# Cast: Judge Justine Payne (anchor; opens scene 1, delivers the verdict in scene 8)
# + the 5 recurring litigant archetypes. Leading-character names emitted by prompt.md
# are the FULL cast names, so each maps to itself (identity aliases override the
# default "first name" collapse, which would turn "Judge Justine Payne" -> "Judge").
# Multi-word names are listed first so they win the substring match unambiguously.
CAST_ALIASES="Judge Justine Payne=Judge Justine Payne,Marlene the Monster-in-Law=Marlene the Monster-in-Law,Trevor the Freeloader=Trevor the Freeloader,Bridezilla Bree=Bridezilla Bree,Dex the Petty Ex=Dex the Petty Ex,Reasonable Ray=Reasonable Ray"

# Single shared PAT (default key YAKYAK_PAT; legacy YAKYAK_BB_PAT also honored).
# PAT_ENV_KEY="YAKYAK_PAT"

# ---- prepare (story sourcing) ---------------------------------------------
# prompt.md driven by `claude -p` (WebFetch + Write).
PREPARE_KIND="prompt"
STORY_SUFFIX="_petty_court.md"
# CI: needs ANTHROPIC_API_KEY + the -claude image.
REQUIRES_MODEL="true"

# ---- CI / scheduling ------------------------------------------------------
# Daily/near-daily — the source is effectively infinite. Disabled until you flip
# ENABLED=true after a local setup + first verified render.
CADENCE="daily"
ENGINE="py"
ENABLED="false"
# Set true to PUBLISH to social on scheduled runs (irreversible). Default render-only.
POST="false"
